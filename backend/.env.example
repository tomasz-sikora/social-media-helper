# Copy this file to .env and fill in your values.

# OpenAI API key – required for LLM summarisation
# Without this the backend falls back to extractive summaries (first sentences)
OPENAI_API_KEY=

# OpenAI model to use for summarisation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: use a different OpenAI-compatible endpoint (e.g. local llama.cpp)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Number of HackerNews top stories to include
HACKERNEWS_TOP_N=30

# Cache TTL in seconds (15 minutes default)
CACHE_TTL_SECONDS=900

# Deduplication similarity threshold (0.0 – 1.0; higher = less aggressive)
DEDUP_SIMILARITY_THRESHOLD=0.85

# REST API server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
