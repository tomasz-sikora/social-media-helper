# Copy this file to .env and fill in your values.

# OpenAI API key – required for LLM summarisation
# Without this the backend falls back to extractive summaries (first sentences)
OPENAI_API_KEY=

# OpenAI model to use for summarisation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: use a different OpenAI-compatible endpoint (e.g. local llama.cpp)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Number of HackerNews top stories to include
HACKERNEWS_TOP_N=30

# Cache TTL in seconds (15 minutes default)
CACHE_TTL_SECONDS=900

# Deduplication similarity threshold (0.0 – 1.0; higher = less aggressive)
DEDUP_SIMILARITY_THRESHOLD=0.85

# REST API server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Stage 2 – Social Platform Integration
# ---------------------------------------------------------------------------

# Nitter instance base URL for Twitter/X RSS feeds (no auth required for public profiles)
# Example public instance:  https://nitter.net
# Self-hosted:              https://nitter.yourdomain.com
# Leave blank to use RSSHub as the Twitter backend instead.
# NITTER_BASE_URL=https://nitter.net

# RSSHub instance base URL – used for Facebook pages, LinkedIn companies, and
# as a Twitter fallback when NITTER_BASE_URL is not set.
# Public instance (rate-limited): https://rsshub.app
# Self-hosted (recommended):      https://rsshub.yourdomain.com
# RSSHUB_BASE_URL=https://rsshub.app

# Twitter/X accounts to follow (comma-separated, @ prefix optional)
# TWITTER_ACCOUNTS=elonmusk,OpenAI,python_tip

# Facebook public pages to follow (comma-separated page names/slugs)
# FACEBOOK_PAGES=bbcnews,nytimes

# LinkedIn company pages to follow (comma-separated company slugs)
# LINKEDIN_COMPANIES=openai,microsoft,google

# ---------------------------------------------------------------------------
# Per-user priority scoring
# ---------------------------------------------------------------------------

# Authors whose content should be boosted to the top of the feed
# (comma-separated names or @handles, case-insensitive)
# PRIORITY_AUTHORS=john_doe,@jane_smith

# Tags whose matching items should be boosted
# (comma-separated, e.g. local community topics)
# PRIORITY_TAGS=kraków,local,community

# Score boost added per matching priority criterion (default: 100)
# PRIORITY_BOOST=100
